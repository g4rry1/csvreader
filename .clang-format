BasedOnStyle: Google
IndentWidth: 4
ColumnLimit: 100

# Keep include groups stable so third-party headers (cmocka.h) stay after
# the standard C headers they depend on.
IncludeBlocks: Regroup
IncludeCategories:
  # Standard C library headers
  - Regex: '^<(assert|complex|ctype|errno|fenv|float|inttypes|iso646|limits|locale|math|setjmp|signal|stdalign|stdarg|stdatomic|stdbool|stddef|stdint|stdnoreturn|stdio|stdlib|string|tgmath|threads|time|uchar|wchar|wctype)\.h>$'
    Priority: 1
  # Third-party angle-bracket headers (e.g. cmocka.h) must come after stdlib
  - Regex: '^<[^/]+\.h>$'
    Priority: 2
  # Project headers
  - Regex: '^".*"$'
    Priority: 3
